# Maintainer: Bilbilak <info@bilbilak.org>
pkgname=claudebar-budgie
pkgver=0.1.0
pkgrel=1
pkgdesc="Budgie panel applet showing Claude.ai Max-plan session and weekly usage"
arch=('x86_64' 'aarch64')
url="https://github.com/bilbilak/claudebar"
license=('GPL3')
depends=('budgie-desktop' 'libpeas' 'json-glib' 'gtk3' 'claudebar-helper')
makedepends=('vala' 'meson' 'ninja' 'pkgconf')
source=("claudebar-$pkgver.tar.gz::https://github.com/bilbilak/claudebar/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "claudebar-$pkgver/apps/linux/budgie"
    meson setup --prefix=/usr --buildtype=release build
    meson compile -C build
}

package() {
    cd "claudebar-$pkgver/apps/linux/budgie"
    meson install -C build --destdir="$pkgdir"
    install -Dm644 "$srcdir/claudebar-$pkgver/LICENSE" \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
