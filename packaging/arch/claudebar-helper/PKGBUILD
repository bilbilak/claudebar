# Maintainer: Bilbilak <info@bilbilak.org>
pkgname=claudebar-helper
pkgver=0.1.0
pkgrel=1
pkgdesc="Shared CLI helper (OAuth + Secret Service + SNI tray) for non-GNOME claudebar front-ends"
arch=('x86_64' 'aarch64')
url="https://github.com/bilbilak/claudebar"
license=('GPL3')
depends=('libsecret' 'dbus' 'gcc-libs')
makedepends=('rust' 'cargo' 'pkgconf')
source=("claudebar-$pkgver.tar.gz::https://github.com/bilbilak/claudebar/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "claudebar-$pkgver/apps/linux/common/claudebar-helper"
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "claudebar-$pkgver/apps/linux/common/claudebar-helper"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release --all-features
}

package() {
    cd "claudebar-$pkgver/apps/linux/common/claudebar-helper"
    install -Dm755 target/release/claudebar-helper \
        "$pkgdir/usr/bin/claudebar-helper"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 "$srcdir/claudebar-$pkgver/LICENSE" \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
