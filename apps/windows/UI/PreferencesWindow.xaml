<Window x:Class="ClaudeBar.UI.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClaudeBar"
        Height="560" Width="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        UseLayoutRounding="True">
    <Grid Margin="12">
        <TabControl>
            <!-- Account -->
            <TabItem Header="Account">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Authentication" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Grid.Row="1" Margin="0,4,0,12" TextWrapping="Wrap"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Text="Sign in with your Claude account to fetch Max-plan usage. Tokens are DPAPI-encrypted per user in %APPDATA%\ClaudeBar."/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Status:" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="Checking…" VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="SignInButton" Content="Sign in with Claude" Padding="12,6"
                                Click="SignInButton_Click"/>
                        <Button x:Name="SignOutButton" Content="Sign out" Padding="12,6" Margin="8,0,0,0"
                                Visibility="Collapsed" Click="SignOutButton_Click"/>
                        <Button x:Name="CancelButton" Content="Cancel" Padding="12,6" Margin="8,0,0,0"
                                Visibility="Collapsed" Click="CancelButton_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="BusyText" Grid.Row="4" Margin="0,4,0,4"
                               Text="Waiting for browser sign-in…"
                               Visibility="Collapsed"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>

                    <TextBlock x:Name="ErrorText" Grid.Row="5" Margin="0,4,0,0" TextWrapping="Wrap"
                               Foreground="#c0392b" Visibility="Collapsed"/>
                </Grid>
            </TabItem>

            <!-- Display -->
            <TabItem Header="Display">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Tray icon" FontWeight="Bold" FontSize="14"/>
                        <CheckBox x:Name="ShowPercentagesCheck" Margin="0,8,0,0"
                                  Content="Show numeric percentages in tooltip and floating meter"
                                  Checked="ShowPercentagesCheck_Changed" Unchecked="ShowPercentagesCheck_Changed"/>
                        <TextBlock Margin="0,4,0,12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   Text="Appends session and weekly percentages to the tray tooltip and the floating meter, if shown."/>

                        <TextBlock Text="Color thresholds" FontWeight="Bold" FontSize="14" Margin="0,12,0,0"/>
                        <TextBlock Margin="0,4,0,8" TextWrapping="Wrap"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   Text="When the bars switch from green to orange to red."/>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Orange at (%):" Width="140" VerticalAlignment="Center"/>
                            <TextBox x:Name="WarnThresholdBox" Width="80" TextAlignment="Right"
                                     PreviewTextInput="NumericInput_Preview" LostFocus="WarnThresholdBox_LostFocus"/>
                            <TextBlock Text="%" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Red at (%):" Width="140" VerticalAlignment="Center"/>
                            <TextBox x:Name="CriticalThresholdBox" Width="80" TextAlignment="Right"
                                     PreviewTextInput="NumericInput_Preview" LostFocus="CriticalThresholdBox_LostFocus"/>
                            <TextBlock Text="%" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Floating desktop meter" FontWeight="Bold" FontSize="14" Margin="0,20,0,0"/>
                        <CheckBox x:Name="FloatingMeterCheck" Margin="0,8,0,0"
                                  Content="Show always-on-top meter on the desktop"
                                  Checked="FloatingMeterCheck_Changed" Unchecked="FloatingMeterCheck_Changed"/>
                        <TextBlock Margin="0,4,0,8" TextWrapping="Wrap"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   Text="Small transparent widget rendering full-size bars. Draggable into any corner; right-click to lock or hide."/>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Opacity:" Width="140" VerticalAlignment="Center"/>
                            <Slider x:Name="OpacitySlider" Width="200" Minimum="40" Maximum="100"
                                    TickFrequency="10" IsSnapToTickEnabled="False"
                                    ValueChanged="OpacitySlider_ValueChanged"/>
                            <TextBlock x:Name="OpacityLabel" Text="92%" Margin="8,0,0,0" VerticalAlignment="Center" Width="44"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Width (px):" Width="140" VerticalAlignment="Center"/>
                            <TextBox x:Name="MeterWidthBox" Width="80" TextAlignment="Right"
                                     PreviewTextInput="NumericInput_Preview" LostFocus="MeterWidthBox_LostFocus"/>
                            <TextBlock Text="(120–320)" Margin="8,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Advanced -->
            <TabItem Header="Advanced">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Refresh" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Grid.Row="1" Margin="0,4,0,12" TextWrapping="Wrap"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Text="How often to refresh usage data. Between 60 and 3600 seconds."/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <TextBlock Text="Poll interval (s):" Width="140" VerticalAlignment="Center"/>
                        <TextBox x:Name="PollIntervalBox" Width="100" TextAlignment="Right"
                                 PreviewTextInput="NumericInput_Preview" LostFocus="PollIntervalBox_LostFocus"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
